{
  "name": "mastercontroller",
  "version": "2.1.2",
  "description": "Fortune 500 ready Node.js MVC framework with enterprise security, monitoring, and horizontal scaling",
  "type": "module",
  "exports": {
    ".": "./MasterControl.js",
    "./security/*.js": "./security/*.js",
    "./monitoring/*.js": "./monitoring/*.js",
    "./error/*.js": "./error/*.js",
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "homepage": "https://github.com/Tailor/MasterController#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tailor/MasterController.git"
  },
  "bugs": {
    "url": "https://github.com/Tailor/MasterController/issues"
  },
  "keywords": [
    "mvc",
    "framework",
    "esm",
    "web",
    "api",
    "rest",
    "enterprise",
    "fortune-500",
    "security",
    "csrf",
    "rate-limiting",
    "monitoring",
    "prometheus",
    "redis",
    "session",
    "horizontal-scaling",
    "load-balancer",
    "production-ready"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "*.js",
    "!eslint.config.js",
    "!prettier.config.js",
    "security/**/*.js",
    "monitoring/**/*.js",
    "error/**/*.js",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "security-audit": "npm audit && npm audit signatures",
    "security-scan": "snyk test --severity-threshold=high",
    "prepare": "npm run lint:check || true",
    "prepublishOnly": "npm run security-audit || true"
  },
  "dependencies": {
    "content-type": "^1.0.5",
    "cookie": "^1.1.1",
    "formidable": "^3.5.4",
    "glob": "^13.0.0",
    "qs": "^6.14.1",
    "winston": "^3.19.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.3.2",
    "prom-client": "^15.1.0"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0",
    "prom-client": "^14.0.0 || ^15.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.2.4"
  }
}
